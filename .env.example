# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moxa NPort 5150A (單串口，兩塊板共用同一 TCP port，不同 Slave ID)
NPORT_HOST=your-factory-static-ip
NPORT_DRYER_PORT=4001
NPORT_MOISTURE_PORT=4001
MODBUS_DRYER_SLAVE_ID=0x01
MODBUS_MOISTURE_SLAVE_ID=0x02
MODBUS_BAUD_RATE=9600

# LINE Messaging API (LINE Official Account 推播)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
# 推播對象 (user ID 或 group ID，留空則廣播給所有好友)
LINE_PUSH_TARGET_ID=

# Cron Secret (Vercel Cron 驗證用)
CRON_SECRET=your-cron-secret
